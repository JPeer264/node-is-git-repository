{
  "name": "is-git-repository",
  "version": "2.0.0",
  "description": "A tool to check if a specific path is a git repository",
  "type": "module",
  "main": "./index.mjs",
  "types": "./index.d.ts",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "eslint index.mjs __tests__",
    "coveralls": "cat ./coverage/lcov.info | coveralls"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm test",
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JPeer264/node-is-git-repository.git"
  },
  "keywords": [
    "is",
    "git",
    "repository",
    "repo",
    "is-git",
    "exists"
  ],
  "author": "Jan Peer Stöcklmair",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/JPeer264/node-is-git-repository/issues"
  },
  "homepage": "https://github.com/JPeer264/node-is-git-repository#readme",
  "dependencies": {
    "execa": "^7.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.4.0",
    "@types/uuid": "^8.0.0",
    "coveralls": "^3.1.0",
    "eslint": "^8.35.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "husky": "^4.2.5",
    "jest": "^29.4.3",
    "lint-staged": "^10.2.11"
  }
}
